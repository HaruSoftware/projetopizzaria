@page "/meus-pedidos"
@using crudcomdb.Models
@using crudcomdb.Interfaces
@inject IPedidoRepository _pedidoRepo
@rendermode InteractiveServer

<h3>Meus Pedidos 📦</h3>

@if (pedidos == null)
{
    <p>Carregando...</p>
}
else if (!pedidos.Any())
{
    <p>Você ainda não fez pedidos.</p>
}
else
{
    <div class="accordion" id="accordionPedidos">
        @foreach (var pedido in pedidos)
        {
            <div class="accordion-item mb-2">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#pedido-@pedido.Id">

                        <strong>#@pedido.Id</strong> &nbsp; | &nbsp;

                        @pedido.Data.ToLocalTime().ToString("dd/MM/yyyy HH:mm") &nbsp; | &nbsp;

                        Status: @pedido.Status &nbsp; | &nbsp;

                        Pago: @(pedido.Pago ? "Sim" : "Não") &nbsp; | &nbsp;

                        Total: R$ @pedido.Total
                    </button>
                </h2>

                <div id="pedido-@pedido.Id"
                     class="accordion-collapse collapse"
                     data-bs-parent="#accordionPedidos">

                    <div class="accordion-body">

                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Produto</th>
                                    <th>Qtd</th>
                                    <th>Preço Unitário</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in pedido.Itens)
                                {
                                    <tr>
                                        <td>@item.Produto?.Nome</td>
                                        <td>@item.Quantidade</td>
                                        <td>R$ @item.PrecoUnitario</td>
                                        <td>R$ @(item.PrecoUnitario* item.Quantidade)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    List<Pedido> pedidos = new();

    protected override async Task OnInitializedAsync()
    {
        pedidos = await _pedidoRepo.Listar();
    }
}