@page "/perfil"
@using crudcomdb.Services
@inject AuthService _auth
@rendermode InteractiveServer

<h3>Perfil do Usuário</h3>

@if (_carregando)
{
    <p>Carregando...</p>
}
else if (_auth.UsuarioLogado == null)
{
    <p>Você não está logado.</p>
}
else
{
    <div class="card p-3" style="width: 300px;">
        <p><strong>Usuário:</strong> @_auth.UsuarioLogado.Username</p>
        <p><strong>Tipo:</strong> @_auth.UsuarioLogado.TipoUsuario</p>
        <p><strong>Valor Atual:</strong> @_auth.ValorAtual</p>
    </div>
}

@code {
    private bool _carregando = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _auth.Inicializar(); // garante recuperar da sessão
            _carregando = false;
            StateHasChanged(); // força atualizar a UI
        }
    }
}